# === Servidor TCP Principal ===
SIM_HOST=0.0.0.0
SIM_PORT=2401
SIM_MAX_CLIENTS=5
SIM_TCP_TIMEOUT_MS=60000

# === Protocolo ===
SIM_PROTOCOL=ascii

# === Comunicación Serie (RS232) ===
# SIM_SERIAL_PORT=COM3
# SIM_SERIAL_BAUDRATE=9600


# === Motor de Estados ===
SIM_ZONE_COUNT=16
SIM_PARTITION_COUNT=2
SIM_HISTORY_LIMIT=1000

# === API de Control (Fastify) ===
SIM_CONTROL_API_HOST=0.0.0.0
SIM_CONTROL_API_PORT=8080

# === Logging ===
SIM_LOG_LEVEL=info

# === Funcionalidades ===
SIM_BROADCAST_ENABLED=true
SIM_LAB_MODE=false
SIM_METRICS_ENABLED=true

# === Escenarios ===
# SIM_SCENARIO_FILE=scenarios/normal-operation.yaml
